<Window x:Class="ChatBox.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:ChatBox.Client.Converters"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="LAN ChatBox" Height="720" Width="1120" Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <cv:Base64ImageConverter x:Key="Base64Converter"/>
        <cv:AvatarInitialsVisibilityConverter x:Key="AvatarInitialsVisConverter"/>
        <cv:FirstLetterConverter x:Key="FirstLetterConverter"/>

        <!-- Premium Custom Scrollbar Thumb Template -->
        <Style x:Key="ScrollThumbs" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid x:Name="Grid">
                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" 
                                    Background="{TemplateBinding Background}" CornerRadius="4" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Thin Track-less ScrollBar just like Discord -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbs}" Background="#C4C9CE" Margin="1,0"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bg" Property="Background" Value="#EAEBED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBoxItem Style for Messages to mimic Discord Hover Highlight -->
        <Style x:Key="DiscordMessageItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="20,6,20,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="MessageBorder" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter />
                                <!-- Floating Quick Reaction Bar - fades in on hover -->
                                <Border x:Name="QuickReactionBar" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-16,-12,0" Background="#FFFFFF" BorderBrush="#E3E5E8" BorderThickness="1"
                                        CornerRadius="8" Padding="4,2" Opacity="0" Visibility="Collapsed" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" Opacity="0.12" ShadowDepth="1"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 👍 button -->
                                        <Button Click="ReactionButton_Click" Tag="👍" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock Text="👍" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 👎 button -->
                                        <Button Click="ReactionButton_Click" Tag="👎" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock Text="👎" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 😂 button -->
                                        <Button Click="ReactionButton_Click" Tag="😂" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock Text="😂" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- ❤️ button (Vibrant Heart with Custom Gray -> Red Style Trigger) -->
                                        <Button Click="ReactionButton_Click" Tag="❤️" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock x:Name="HeartText" Text="❤" FontSize="15" Foreground="#747F8D" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Setter TargetName="HeartText" Property="Foreground" Value="#ED4245"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 😮 button -->
                                        <Button Click="ReactionButton_Click" Tag="😮" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock Text="😮" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 😢 button -->
                                        <Button Click="ReactionButton_Click" Tag="😢" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="1,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                        <emoji:TextBlock Text="😢" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <emoji:TextBlock.RenderTransform>
                                                                <ScaleTransform x:Name="EmojiScale" ScaleX="1" ScaleY="1"/>
                                                            </emoji:TextBlock.RenderTransform>
                                                        </emoji:TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="EmojiScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover Effect: subtle grey background hover + show quick reaction bar -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MessageBorder" Property="Background" Value="#F8F9FA"/>
                                <Setter TargetName="QuickReactionBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="QuickReactionBar" Property="Opacity" Value="1"/>
                            </Trigger>
                            <!-- Disable selection box highlight entirely -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="MessageBorder" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#4752C4"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3B429A"/>
                                <Setter TargetName="BtnBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Settings TextBox Style -->
        <Style x:Key="ModernSettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F2F3F5"/>
            <Setter Property="Foreground" Value="#2E3338"/>
            <Setter Property="BorderBrush" Value="#E3E5E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#B5BAC1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F2F3F5"/>
            <Setter Property="BorderBrush" Value="#E3E5E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="12,0" VerticalContentAlignment="Center" FontSize="13" Foreground="#2E3338" SelectionBrush="#5865F2"/>
                                <ToggleButton Grid.Column="1" x:Name="toggle" Background="Transparent" BorderThickness="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Width="30" Height="38">
                                                <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0" Stroke="#4F5660" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False">
                                    <Border Background="#FFFFFF" BorderBrush="#E3E5E8" BorderThickness="1" CornerRadius="6" Width="{TemplateBinding ActualWidth}" MaxHeight="200" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" Opacity="0.1" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter SnapsToDevicePixels="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#B5BAC1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings Modern Button (Blurple) -->
        <Style x:Key="SettingsModernButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Height" Value="38"/>
        </Style>
        
        <!-- Settings Danger Button (Red) -->
        <Style x:Key="SettingsDangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#ED4245"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#C03537"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#A02A2C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Settings Success Button (Green) -->
        <Style x:Key="SettingsSuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#23A55A"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1A7F43"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#156635"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Settings Secondary Button (Outline) -->
        <Style x:Key="SettingsSecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4F5660"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="#D4D7DC" BorderThickness="1" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#F2F3F5"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#B5BAC1"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E3E5E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="#FFFFFF" BorderBrush="#E3E5E8" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        <!-- Premium Custom Title Topbar -->
        <Border Grid.Row="0" Background="#F2F3F5" BorderBrush="#E3E5E8" BorderThickness="0,0,0,1" Height="32" MouseLeftButtonDown="Topbar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand logo and name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False">
                    <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LAN ChatBox" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold" Foreground="#4F5660" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- System close, maximize and minimize control buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <!-- Minimize -->
                    <Button x:Name="btnMinimize" Width="46" VerticalAlignment="Stretch" Click="BtnMinimize_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="B" Background="Transparent">
                                    <Path x:Name="P" Data="M0,6 L10,6" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                        <Setter TargetName="P" Property="Stroke" Value="#060607"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#D4D7DC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Maximize -->
                    <Button x:Name="btnMaximize" Width="46" VerticalAlignment="Stretch" Click="BtnMaximize_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="B" Background="Transparent">
                                    <Path x:Name="P" Data="M1,1 H9 V9 H1 Z" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                        <Setter TargetName="P" Property="Stroke" Value="#060607"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#D4D7DC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close -->
                    <Button x:Name="btnClose" Width="46" VerticalAlignment="Stretch" Click="BtnClose_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="B" Background="Transparent" CornerRadius="0,8,0,0">
                                    <Path x:Name="P" Data="M1,1 L9,9 M1,9 L9,1" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#ED4245"/>
                                        <Setter TargetName="P" Property="Stroke" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="B" Property="Background" Value="#C03537"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Window Layout Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Leftmost Discord Server List Sidebar (width 70) -->
        <Border Grid.Column="0" Background="#E3E5E8" Padding="0,15,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <!-- Home Server Icon with Left Active Pill -->
                    <Grid Margin="0,0,0,8" ToolTip="LAN Global Chat">
                        <!-- Active Pill (vertical capsule) -->
                        <Border Width="4" Height="40" Background="#060607" CornerRadius="2" HorizontalAlignment="Left" Margin="-11,0,0,0" VerticalAlignment="Center"/>
                        
                        <Border Width="48" Height="48" CornerRadius="16" Background="#5865F2" Cursor="Hand">
                            <TextBlock Text="💬" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                    </Grid>
                    
                    <!-- Decorative separator -->
                    <Border Width="32" Height="2" Background="#D4D7DC" Margin="0,4,0,8" CornerRadius="1"/>
                    
                    <!-- Dummy Server 2 (File Share Channel) -->
                    <Grid Margin="0,0,0,8" ToolTip="File Sharing Server">
                        <Border x:Name="srvFileShare" Width="48" Height="48" CornerRadius="24" Background="#FFFFFF" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="CornerRadius" Value="16"/>
                                            <Setter Property="Background" Value="#5865F2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="📁" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <!-- Dummy Server 3 (Gaming Community) -->
                    <Grid Margin="0,0,0,8" ToolTip="Gaming Server">
                        <Border x:Name="srvGaming" Width="48" Height="48" CornerRadius="24" Background="#FFFFFF" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="CornerRadius" Value="16"/>
                                            <Setter Property="Background" Value="#23A55A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🎮" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Add Server Icon -->
                    <Grid Margin="0,0,0,8" ToolTip="Add a Server">
                        <Border Width="48" Height="48" CornerRadius="24" Background="#FFFFFF" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="CornerRadius" Value="16"/>
                                            <Setter Property="Background" Value="#23A55A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="＋" FontSize="20" Foreground="#23A55A" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </StackPanel>
                
                <!-- Bottom Profile Avatar Selector (Initials fallback overlapping system) -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15" HorizontalAlignment="Center">
                    <Grid Width="48" Height="48" Cursor="Hand" ToolTip="Click to change avatar" MouseUp="BtnChangeAvatar_Click">
                        <!-- Solid color circle (fallback) -->
                        <Ellipse Width="48" Height="48" Fill="#5865F2"/>
                        <!-- Initials Text (fallback) -->
                        <TextBlock x:Name="lblAvatarInitials" Text="C" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        <!-- Image uploaded (on top) -->
                        <Ellipse Width="48" Height="48" Stroke="#5865F2" StrokeThickness="2">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgAvatar" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Channel list sidebar (width 250) -->
        <Border Grid.Column="1" Background="#F2F3F5" BorderBrush="#E3E5E8" BorderThickness="0,0,1,0">
            <Grid SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="52"/>
                </Grid.RowDefinitions>
                
                <!-- Server Title Header -->
                <Border Grid.Row="0" BorderBrush="#E3E5E8" BorderThickness="0,0,0,1" Padding="16,0" Cursor="Hand" ToolTip="Server Menu">
                    <Grid>
                        <TextBlock Text="LAN SERVER HUB" FontSize="12" FontWeight="Bold" Foreground="#060607" VerticalAlignment="Center"/>
                        <TextBlock Text="▼" FontSize="9" Foreground="#4F5660" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Channels List Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,16,8,0">
                        <!-- TEXT CHANNELS header -->
                        <Grid Margin="8,0,0,8">
                            <TextBlock Text="TEXT CHANNELS" FontSize="11" FontWeight="Bold" Foreground="#4F5660" VerticalAlignment="Center"/>
                            <TextBlock Text="+" FontSize="14" Foreground="#4F5660" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Cursor="Hand" ToolTip="Create Channel"/>
                        </Grid>
                                    <!-- TEXT CHANNELS items -->
                        <!-- # Dynamic Chat Channel (Selected/Active by default) -->
                        <Border x:Name="borderChanChat" Background="#E3E5E8" CornerRadius="4" Padding="8,6" Margin="0,0,0,2" Cursor="Hand" MouseLeftButtonDown="ChanChat_Click" ToolTip="Active General Chat">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="16" Foreground="#4F5660" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtChanChat" Grid.Column="1" Text="lan-global-chat" FontSize="13" FontWeight="Bold" Foreground="#060607" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <!-- # Images Channel (Inactive by default) -->
                        <Border x:Name="borderChanImages" CornerRadius="4" Padding="8,6" Margin="0,0,0,2" Cursor="Hand" MouseLeftButtonDown="ChanImages_Click" ToolTip="Image &amp; Media Uploads">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EBEDF0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🖼️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtChanImages" Grid.Column="1" Text="images-only" FontSize="13" Foreground="#4F5660" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- # Files Channel (Inactive by default) -->
                        <Border x:Name="borderChanFiles" CornerRadius="4" Padding="8,6" Margin="0,0,0,2" Cursor="Hand" MouseLeftButtonDown="ChanFiles_Click" ToolTip="Other File Attachments">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EBEDF0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtChanFiles" Grid.Column="1" Text="files-only" FontSize="13" Foreground="#4F5660" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Bottom User Profile Footer (Exactly like Discord) -->
                <Border Grid.Row="2" Background="#EBEDF0" Padding="8,4" BorderBrush="#E3E5E8" BorderThickness="0,1,0,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Avatar with green status dot overlapping -->
                        <Grid Grid.Column="0" Margin="4,0,8,0" Cursor="Hand" MouseUp="BtnChangeAvatar_Click" ToolTip="Change Avatar">
                            <Ellipse Width="32" Height="32" Fill="#5865F2"/>
                            <TextBlock x:Name="lblFooterInitials" Text="C" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            <Ellipse Width="32" Height="32">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgFooterAvatar" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- Green status dot bottom right -->
                            <Ellipse x:Name="footerStatusDot" Width="10" Height="10" Fill="#747F8D" Stroke="#EBEDF0" StrokeThickness="1.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"/>
                        </Grid>
                        
                        <!-- Username details -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock x:Name="lblFooterUsername" Text="Camellya" FontSize="13" FontWeight="Bold" Foreground="#060607" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="lblFooterStatus" Text="Offline" FontSize="11" Foreground="#4F5660" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <!-- Controls: Settings Gear -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Settings Gear Icon (Triggers settings dialog) -->
                            <Button Content="⚙️" FontSize="12" Width="28" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnShowSettings_Click" ToolTip="Connection Settings">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="B" Background="Transparent" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Right Chat Area -->
        <Grid Grid.Column="2" x:Name="pnlChat" IsEnabled="False" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" BorderBrush="#E3E5E8" BorderThickness="0,0,0,1" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="💬" FontSize="18" Foreground="#4F5660" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblRoomName" Text="# lan-global-chat" FontSize="15" FontWeight="Bold" Foreground="#060607" VerticalAlignment="Center"/>
                        <Border Height="16" Width="1" Background="#D4D7DC" Margin="12,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblGreeting" Text="Welcome to the server!" FontSize="12" Foreground="#747F8D" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Icons on the right -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="btnInfo" Width="28" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnInfo_Click" ToolTip="Member List">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Border.RenderTransform>
                                        <TextBlock x:Name="Icon" Text="👥" FontSize="18" Foreground="#4F5660" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Icon" Property="Opacity" Value="1.0"/>
                                            <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Popup x:Name="popupInfo" PlacementTarget="{Binding ElementName=btnInfo}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="5" HorizontalOffset="-150">
                            <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E3E5E8" BorderThickness="1" Width="220">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="ONLINE MEMBERS" FontSize="11" FontWeight="Bold" Foreground="#4F5660" Margin="0,0,0,10"/>
                                    <ListBox x:Name="lstOnlineUsers" BorderThickness="0" MaxHeight="250">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,4" Cursor="Hand">
                                                    <!-- Circle placeholder icon with user initials look -->
                                                    <Grid Margin="0,0,10,0">
                                                        <Ellipse Width="24" Height="24" Fill="#5865F2"/>
                                                        <TextBlock Text="👤" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="13" Foreground="#060607" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Message List (Discord style left-aligned) -->
            <ListBox x:Name="lstChatMessages" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0,10,0,0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     PreviewMouseWheel="SmoothScrollViewer_PreviewMouseWheel"
                     ItemContainerStyle="{StaticResource DiscordMessageItemStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="MsgGrid" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" x:Name="AvatarCol"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Avatar on the left -->
                            <Grid x:Name="AvatarGrid" Grid.Column="0" Width="40" Height="40" VerticalAlignment="Top" HorizontalAlignment="Center">
                                <Ellipse x:Name="imgMsgAvatar" Width="40" Height="40" VerticalAlignment="Top" HorizontalAlignment="Center">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding AvatarBase64, Converter={StaticResource Base64Converter}}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="40" Height="40" VerticalAlignment="Top" HorizontalAlignment="Center"
                                         Fill="#5865F2"
                                         Visibility="{Binding AvatarBase64, Converter={StaticResource AvatarInitialsVisConverter}}"/>
                                <TextBlock Text="{Binding Sender, Converter={StaticResource FirstLetterConverter}}"
                                           FontSize="16" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding AvatarBase64, Converter={StaticResource AvatarInitialsVisConverter}}"/>
                            </Grid>
                            
                            <!-- Message Content Pane on the right -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                                <StackPanel x:Name="HeaderPanel" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock x:Name="lblSenderName" Text="{Binding Sender}" FontWeight="Bold" FontSize="14" Foreground="#060607" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="#747F8D" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                </StackPanel>                                <!-- File Attachment Embed (Discord Embed look) -->
                                <Border x:Name="FileEmbedBorder" Background="#F2F3F5" CornerRadius="4" BorderBrush="#E3E5E8" BorderThickness="1" Padding="12" Margin="0,4,0,5" Visibility="{Binding ShowFileControl, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Width="350">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📄" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <emoji:TextBlock Text="{Binding Content}" FontSize="13" FontWeight="Bold" Foreground="#060607" TextWrapping="Wrap"/>
                                            <TextBlock Text="File Attachment" FontSize="11" Foreground="#747F8D" Margin="0,1,0,6"/>
                                            <Button x:Name="btnDownloadEmbed" Content="Download File" Tag="{Binding}" Background="#4F545C" Foreground="White" Width="95" Height="26" Cursor="Hand" Click="BtnDownload_Click" FontSize="11" FontWeight="Bold">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="3"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            <!-- Upload/Download progress -->
                                            <ProgressBar Height="4" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" Margin="0,6,0,0" BorderThickness="0" x:Name="EmbedProgress" Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <!-- Remove button for draft files (X in top-right corner) -->
                                        <Button x:Name="btnRemoveDraftFile" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4,-4,0,0" Width="22" Height="22" Background="#ED4245" BorderThickness="0" Cursor="Hand" Click="BtnRemovePending_Click" Tag="{Binding}" Visibility="Collapsed">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="B" Background="#ED4245" CornerRadius="11" Opacity="0.9">
                                                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="B" Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <!-- Image Attachment (Discord style inline image viewer) -->
                                <Border x:Name="ImageEmbedBorder" CornerRadius="8" Margin="0,4,0,5" Visibility="{Binding ShowImageControl, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" MaxWidth="350" Background="#F2F3F5" BorderThickness="1" BorderBrush="#E3E5E8" Padding="4" Cursor="Hand" MouseLeftButtonDown="ChatImage_Click" Tag="{Binding}" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Image x:Name="imgEmbedControl" Source="{Binding LocalFilePath}" Stretch="Uniform" MaxWidth="340" MaxHeight="250"/>

                                        <!-- Upload/Download progress for Image -->
                                        <ProgressBar Grid.Row="1" Height="4" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" Margin="0,4,0,0" BorderThickness="0" x:Name="ImageProgress" Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Remove button for draft images (X in top-right corner) -->
                                        <Button x:Name="btnRemoveDraftImage" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-8,0" Width="22" Height="22" Background="#ED4245" BorderThickness="0" Cursor="Hand" Click="BtnRemovePending_Click" Tag="{Binding}" Visibility="Collapsed">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="B" Background="#ED4245" CornerRadius="11" Opacity="0.9">
                                                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="B" Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Sender Info Details (only visible in Images Channel when Selected/Clicked) -->
                                <Border x:Name="ImageSenderDetails" Background="#F2F3F5" CornerRadius="0,0,8,8" Padding="12,8" BorderBrush="#E3E5E8" BorderThickness="1,0,1,1" Margin="0,-5,0,5" Visibility="Collapsed" MaxWidth="700" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="24" Height="24" Margin="0,0,8,0">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding AvatarBase64, Converter={StaticResource Base64Converter}}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Sender}" FontWeight="Bold" FontSize="12" Foreground="#060607" VerticalAlignment="Center"/>
                                        <TextBlock Text=" sent at " FontSize="11" Foreground="#747F8D" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Timestamp}" FontSize="11" FontWeight="SemiBold" Foreground="#4F5660" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <emoji:TextBlock x:Name="txtMsgContent" Text="{Binding DisplayText}" FontSize="15" Foreground="#2E3338" TextWrapping="Wrap"/>

                                <!-- Reactions Display Panel -->
                                <ItemsControl x:Name="ReactionsPanel" ItemsSource="{Binding Reactions}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F2F3F5" CornerRadius="10" BorderBrush="#E3E5E8" BorderThickness="1" Padding="6,2" Margin="0,0,4,0" Cursor="Hand" ToolTip="{Binding UserNames}">
                                                <StackPanel Orientation="Horizontal">
                                                    <emoji:TextBlock Text="{Binding Emoji}" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" FontSize="11" Foreground="#4F5660" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- System message styling -->
                            <DataTrigger Binding="{Binding Sender}" Value="System">
                                <Setter TargetName="AvatarGrid" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="AvatarCol" Property="Width" Value="0"/>
                                <Setter TargetName="HeaderPanel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="txtMsgContent" Property="Foreground" Value="#747F8D"/>
                                <Setter TargetName="txtMsgContent" Property="FontSize" Value="13"/>
                                <Setter TargetName="txtMsgContent" Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                            <!-- File styling -->
                            <DataTrigger Binding="{Binding IsFile}" Value="True">
                                <Setter TargetName="txtMsgContent" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <!-- Me styling (colored name) -->
                            <DataTrigger Binding="{Binding IsMe}" Value="True">
                                <Setter TargetName="lblSenderName" Property="Foreground" Value="#5865F2"/>
                            </DataTrigger>

                            <!-- Draft image styling (dashed purple border) -->
                            <DataTrigger Binding="{Binding IsDraft}" Value="True">
                                <Setter TargetName="ImageEmbedBorder" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="ImageEmbedBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="ImageEmbedBorder" Property="Opacity" Value="0.85"/>
                                <Setter TargetName="btnRemoveDraftImage" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="btnRemoveDraftFile" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            
                            <!-- Custom styling for Image Only Channel -->
                            <DataTrigger Binding="{Binding IsInImageChannel}" Value="True">
                                <Setter TargetName="imgMsgAvatar" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="HeaderPanel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="AvatarCol" Property="Width" Value="0"/>
                                <Setter TargetName="ImageEmbedBorder" Property="MaxWidth" Value="700"/>
                                <Setter TargetName="imgEmbedControl" Property="MaxWidth" Value="690"/>
                                <Setter TargetName="imgEmbedControl" Property="MaxHeight" Value="500"/>
                            </DataTrigger>
                            
                            <!-- Show Sender Details below image on click/selection in Image Channel -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsInImageChannel}" Value="True"/>
                                    <Condition Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ImageSenderDetails" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ImageEmbedBorder" Property="CornerRadius" Value="8,8,0,0"/>
                            </MultiDataTrigger>
                            
                            <!-- Hover outline / scale for chat images -->
                            <Trigger SourceName="ImageEmbedBorder" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ImageEmbedBorder" Property="BorderBrush" Value="#5865F2"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ImageEmbedBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ImageEmbedBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ImageEmbedBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ImageEmbedBorder" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Dedicated Images-only Gallery view -->
            <ScrollViewer x:Name="scrollImageGallery" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed" Background="Transparent" PreviewMouseWheel="SmoothScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="itemsImageGallery">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,24">
                                <!-- Date Header -->
                                <TextBlock Text="{Binding DateHeader}" FontSize="15" FontWeight="Bold" Foreground="#4F5660" Margin="20,12,20,12"/>
                                
                                <!-- 4-Column Grid of Images -->
                                <ItemsControl ItemsSource="{Binding Images}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" Margin="14,0,14,0"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="ImgCard" CornerRadius="8" Margin="6" Background="#F2F3F5" BorderThickness="1" BorderBrush="#E3E5E8" Height="150" Cursor="Hand" MouseLeftButtonDown="GalleryImage_Click" Tag="{Binding}" RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                                </Border.RenderTransform>
                                                <Grid>
                                                    <Border CornerRadius="8" ClipToBounds="True">
                                                        <!-- Image -->
                                                        <Image Source="{Binding LocalFilePath}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <!-- Overlay if transferring -->
                                                    <ProgressBar Height="4" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" VerticalAlignment="Bottom" BorderThickness="0" Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ImgCard" Property="BorderBrush" Value="#5865F2"/>
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ImgCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="ImgCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ImgCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="ImgCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Dedicated Files-only Gallery view -->
            <ScrollViewer x:Name="scrollFileGallery" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed" Background="Transparent" PreviewMouseWheel="SmoothScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="itemsFileGallery">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,24">
                                <!-- Date Header -->
                                <TextBlock Text="{Binding DateHeader}" FontSize="15" FontWeight="Bold" Foreground="#4F5660" Margin="20,12,20,12"/>
                                
                                <!-- 4-Column Grid of Files -->
                                <ItemsControl ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" Margin="14,0,14,0"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="FileCard" CornerRadius="8" Margin="6" Background="#F2F3F5" BorderThickness="1" BorderBrush="#E3E5E8" Height="150" Cursor="Hand" MouseLeftButtonDown="GalleryFile_Click" Tag="{Binding}" RenderTransformOrigin="0.5,0.5" Padding="12">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                                </Border.RenderTransform>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- File Icon -->
                                                    <TextBlock Grid.Row="0" Text="📄" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,4"/>
                                                    
                                                    <!-- File Details -->
                                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Content}" FontSize="12" FontWeight="Bold" Foreground="#060607" TextAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Content}"/>
                                                        <TextBlock FontSize="10" Foreground="#747F8D" TextAlignment="Center" Margin="0,2,0,0">
                                                            <TextBlock.Text>
                                                                <Binding Path="FileSize" StringFormat="{}{0:N0} bytes"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Transfer Progress -->
                                                    <ProgressBar Grid.Row="2" Height="4" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" BorderThickness="0" Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="FileCard" Property="BorderBrush" Value="#5865F2"/>
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="FileCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="FileCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="FileCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="FileCard" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Draft Image Staging Panel -->
            <ScrollViewer x:Name="DraftStagingPanel" Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="20,10,20,0" Visibility="Collapsed">
                <ItemsControl x:Name="DraftStagingItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="112" Height="112" Margin="0,0,8,0" Tag="{Binding}">
                            <Border CornerRadius="6" ClipToBounds="True" Background="#E3E5E8">
                                <Image Source="{Binding LocalFilePath}" Stretch="UniformToFill"/>
                            </Border>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                                    Width="18" Height="18" Background="#ED4245" BorderThickness="0" Cursor="Hand"
                                    Click="BtnRemovePending_Click" Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="B" Background="#ED4245" CornerRadius="9" Opacity="0.9">
                                            <TextBlock Text="✕" Foreground="White" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="B" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area (Discord style inner box) -->
            <Grid Grid.Row="3" Margin="20,10,20,24">
                <Border x:Name="borderInputArea" Background="#F2F3F5" CornerRadius="8" Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
 
                        <!-- Plus button inside input -->
                        <Button Grid.Column="0" Content="+" Width="24" Height="24" 
                                Background="#4F5660" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"
                                Margin="0,0,10,0" Click="BtnUpload_Click" ToolTip="Send a File">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#747F8D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
 
                        <Grid Grid.Column="1">
                            <emoji:RichTextBox x:Name="txtInput" FontSize="14" 
                                               Background="Transparent" BorderThickness="0" 
                                               Padding="5,4" ColonSyntax="True" TextChanged="TxtInput_TextChanged"
                                               PreviewKeyDown="TxtInput_PreviewKeyDown"
                                               IsUndoEnabled="False">
                                <emoji:RichTextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </emoji:RichTextBox.Resources>
                            </emoji:RichTextBox>
                            <!-- Beautiful Discord-style Placeholder -->
                            <TextBlock x:Name="lblInputPlaceholder" Text="Message #lan-global-chat" Foreground="#747F8D" FontSize="14" Padding="5,4" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
 
                        <!-- Emoji button inside input -->
                        <Button Grid.Column="2" x:Name="btnEmoji" Width="28" Height="28" 
                                Background="Transparent" BorderThickness="0" Margin="5,0,5,0" ToolTip="Choose Emoji" Click="BtnEmoji_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent" CornerRadius="14" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Border.RenderTransform>
                                        <emoji:TextBlock x:Name="Icon" Text="😀" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Icon" Property="Opacity" Value="1.0"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                </Setter.Value>
                                             </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
 
                        <!-- Send Button -->
                        <Button Grid.Column="3" Width="28" Height="28" Margin="5,0,0,0" 
                                Background="Transparent" BorderThickness="0" Click="BtnSendChat_Click" Cursor="Hand" ToolTip="Send Message">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent" CornerRadius="14" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Border.RenderTransform>
                                        <TextBlock x:Name="Icon" Text="➤" FontSize="16" Foreground="#5865F2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7" Margin="2,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Icon" Property="Opacity" Value="1.0"/>
                                            <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                </Setter.Value>
                                             </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
 
                <Popup x:Name="popupEmoji" StaysOpen="False" PlacementTarget="{Binding ElementName=btnEmoji}" Placement="Top" AllowsTransparency="True" VerticalOffset="-10">
                    <Border Background="White" CornerRadius="12" Padding="8,8,0,8" BorderBrush="#E3E5E8" BorderThickness="1" Width="315" Height="280">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="4"/>
                        </Border.Effect>
                        <TabControl x:Name="tabEmojis" BorderThickness="0" Background="Transparent">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="HeaderTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <emoji:TextBlock Text="{Binding}" FontSize="16"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border Name="Border" Margin="2,0,2,2" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F0F2F5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F5F7F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>
                            <TabItem Header="😀" ToolTip="Smileys &amp; People">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlSmileys" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="🐱" ToolTip="Animals &amp; Nature">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlAnimals" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="🍔" ToolTip="Food &amp; Drink">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlFood" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="⚽" ToolTip="Activities">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlActivities" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="🌇" ToolTip="Travel &amp; Places">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlTravel" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="💡" ToolTip="Objects &amp; Symbols">
                                <ScrollViewer Width="292" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                    <WrapPanel x:Name="pnlObjects" Margin="2,0,0,0"/>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
        
        <!-- Settings Overlay Screen (Discord-style User Settings Dialog spanning all 3 columns) -->
        <Grid x:Name="settingsOverlay" Grid.Column="0" Grid.ColumnSpan="3" Visibility="Collapsed" Panel.ZIndex="100">
            <Grid.Background>
                <SolidColorBrush Color="#000000" Opacity="0.55"/>
            </Grid.Background>
            
            <Border Width="680" Height="500" Background="#FFFFFF" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" Opacity="0.15" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Sidebar of Settings Panel -->
                    <Border Grid.Column="0" Background="#F2F3F5" CornerRadius="12,0,0,12" Padding="24">
                        <StackPanel>
                            <TextBlock Text="USER SETTINGS" FontSize="11" FontWeight="Bold" Foreground="#4F5660" Margin="0,0,0,15"/>
                            <Border Background="#E3E5E8" Height="36" CornerRadius="4" Padding="12,0" Margin="0,0,0,5">
                                <TextBlock Text="Profile &amp; Connection" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#060607"/>
                            </Border>
                            
                            <Border Height="1" Background="#D4D7DC" Margin="0,20"/>
                            
                            <TextBlock Text="APP VERSION" FontSize="9" FontWeight="Bold" Foreground="#747F8D" Margin="0,0,0,4"/>
                            <TextBlock Text="v1.1.2 (GG Sans UI)" FontSize="11" Foreground="#4F5660" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Right Content of Settings Panel -->
                    <Grid Grid.Column="1" Margin="30,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="My Profile &amp; Server Connection" FontSize="20" FontWeight="Bold" Foreground="#060607" Margin="0,0,0,24"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <!-- Display name input -->
                                <TextBlock Text="DISPLAY NAME" Foreground="#4F5660" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtUsername" Text="User" Height="38" Margin="0,0,0,20" Style="{StaticResource ModernSettingsTextBox}" SelectionBrush="#5865F2" TextChanged="TxtUsername_TextChanged"/>
                                
                                <!-- Server connection inputs -->
                                <TextBlock Text="SERVER CONNECTION IP" Foreground="#4F5660" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cboServerIp" IsEditable="True" Text="127.0.0.1" Height="38" Style="{StaticResource ModernComboBox}"/>
                                    <Button Grid.Column="1" Content="Clear" Width="60" Style="{StaticResource SettingsDangerButton}" Margin="8,0,0,0" Click="BtnClearIps_Click" FontSize="12" FontWeight="Bold"/>
                                </Grid>
                                
                                <!-- Avatar selection block -->
                                <TextBlock Text="AVATAR SELECTION" Foreground="#4F5660" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Content="Upload Avatar Image" Width="150" Height="38" Style="{StaticResource SettingsModernButton}" Click="BtnChangeAvatar_Click" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Click to upload custom square image." VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#747F8D" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <!-- Footer connection controls and Close button -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <!-- Left-aligned connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Ellipse x:Name="statusIndicator" Width="10" Height="10" Fill="#747F8D" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblStatus" Text="Disconnected" FontSize="13" FontWeight="Bold" Foreground="#4F5660" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Right-aligned action buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnConnect" Content="Connect to Server" Width="140" Height="38" Style="{StaticResource SettingsSuccessButton}" Click="BtnConnect_Click" Margin="0,0,10,0"/>
                                <Button x:Name="btnCancelConnect" Content="Cancel" Width="140" Height="38" Style="{StaticResource SettingsSecondaryButton}" Click="BtnCancelConnect_Click" Visibility="Collapsed" Margin="0,0,10,0"/>
                                <Button x:Name="btnDisconnect" Content="Disconnect" Width="140" Height="38" Style="{StaticResource SettingsDangerButton}" Click="BtnDisconnect_Click" Visibility="Collapsed" Margin="0,0,10,0"/>
                                <Button Content="Close" Width="80" Height="38" Style="{StaticResource SettingsSecondaryButton}" Click="BtnCloseSettings_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Lightbox Fullscreen Popup Modal -->
        <Grid x:Name="lightboxOverlay" Visibility="Collapsed" Background="#D8000000" Grid.ColumnSpan="3" Grid.RowSpan="4" Panel.ZIndex="999" MouseLeftButtonDown="CloseLightbox_Click">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Close Button at top-right -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-30,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseLightbox_Click" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="Txt" Text="✕" Foreground="White" Opacity="0.75" FontSize="26" FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Txt" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="Txt" Property="Foreground" Value="#ED4245"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.2" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.2" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Txt" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Large Image Container -->
                <Border Background="#F2F3F5" CornerRadius="8,8,0,0" BorderBrush="#E3E5E8" BorderThickness="1" MaxWidth="800" MaxHeight="600" Padding="8">
                    <Image x:Name="imgLightboxLarge" Stretch="Uniform" MaxWidth="780" MaxHeight="580" Cursor="Hand"/>
                </Border>

                <!-- Information Bar & Download Button below Image -->
                <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="0,0,8,8" BorderBrush="#E3E5E8" BorderThickness="1,0,1,1" Padding="16,12" MaxWidth="800">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Sender & Timestamp Info -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="32" Height="32" Margin="0,0,12,0">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgLightboxAvatar" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblLightboxSender" FontWeight="Bold" FontSize="13" Foreground="#060607"/>
                                <TextBlock x:Name="lblLightboxTime" FontSize="11" Foreground="#747F8D" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Premium Discord-Style Download Button -->
                        <Button Grid.Column="1" x:Name="btnLightboxDownload" Width="100" Height="32" Cursor="Hand" Click="LightboxDownload_Click" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="#5865F2" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                        </Border.RenderTransform>
                                        <TextBlock Text="Download" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#4752C4"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                        <DoubleAnimation Storyboard.TargetName="B" Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#3B429A"/>
                                            <Setter TargetName="B" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Border>
</Window>
