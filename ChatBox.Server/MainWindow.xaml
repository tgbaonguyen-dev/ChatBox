<Window x:Class="ChatBox.Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatBox Central Server" Height="600" Width="850" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResize">
    <Window.Resources>
        <!-- Premium Custom Scrollbar Thumb Template -->
        <Style x:Key="ScrollThumbs" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid x:Name="Grid">
                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" 
                                    Background="{TemplateBinding Background}" CornerRadius="4" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Thin Track-less ScrollBar just like Discord -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbs}" Background="#C4C9CE" Margin="1,0"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bg" Property="Background" Value="#EAEBED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F2F3F5"/>
            <Setter Property="Foreground" Value="#2E3338"/>
            <Setter Property="BorderBrush" Value="#E3E5E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#B5BAC1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4752C4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#3C45A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#DA373C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#A92B2F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#8F2428"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="#FFFFFF" BorderBrush="#E3E5E8" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Premium Custom Title Topbar -->
            <Border Grid.Row="0" Background="#F2F3F5" BorderBrush="#E3E5E8" BorderThickness="0,0,0,1" Height="32" MouseLeftButtonDown="Topbar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand logo and name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False">
                        <TextBlock Text="⚙️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="LAN ChatBox Central Server" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold" Foreground="#4F5660" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- System Close, Maximize and Minimize Control Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                        <!-- Minimize -->
                        <Button x:Name="btnMinimize" Width="46" VerticalAlignment="Stretch" Click="BtnMinimize_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent">
                                        <Path x:Name="P" Data="M0,6 L10,6" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                            <Setter TargetName="P" Property="Stroke" Value="#060607"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#D4D7DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Maximize -->
                        <Button x:Name="btnMaximize" Width="46" VerticalAlignment="Stretch" Click="BtnMaximize_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent">
                                        <Path x:Name="P" Data="M1,1 H9 V9 H1 Z" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                            <Setter TargetName="P" Property="Stroke" Value="#060607"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#D4D7DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Close -->
                        <Button x:Name="btnClose" Width="46" VerticalAlignment="Stretch" Click="BtnClose_Click" Background="Transparent" BorderThickness="0" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="B" Background="Transparent" CornerRadius="0,8,0,0">
                                        <Path x:Name="P" Data="M1,1 L9,9 M1,9 L9,1" Stroke="#4F5660" StrokeThickness="1.2" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#ED4245"/>
                                            <Setter TargetName="P" Property="Stroke" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#C03537"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Server Layout Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar Settings Panel -->
                <Border Grid.Column="0" Background="#F2F3F5" Padding="16" BorderBrush="#E3E5E8" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="SERVER STATUS" Foreground="#5865F2" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Border Height="2" Background="#E3E5E8" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Form Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,4,0">
                                <!-- IP Info Box -->
                                <Border Background="#FFFFFF" CornerRadius="8" Padding="12,10" BorderBrush="#E3E5E8" BorderThickness="1" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Hosting IP(s) - LAN" FontSize="11" Foreground="#4F5660" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="lblHostingIps" Text="Detecting..." FontSize="13" Foreground="#23A55A" FontWeight="Bold" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" x:Name="btnCopyIp" Width="32" Height="32" Margin="8,0,0,0" ToolTip="Copy IP to clipboard" Click="BtnCopyIp_Click" Background="#F2F3F5" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="16">
                                                        <Path x:Name="P" Data="M3,3 H11 V11 H3 Z M5,1 H13 V9 H12" Stroke="#4F5660" StrokeThickness="1.2" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="B" Property="Background" Value="#E3E5E8"/>
                                                            <Setter TargetName="P" Property="Stroke" Value="#5865F2"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="B" Property="Background" Value="#D4D7DC"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Room Name Field -->
                                <TextBlock Text="ROOM NAME" FontSize="11" Foreground="#4F5660" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtRoomName" Text="LAN Global Chat" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                                <Button x:Name="btnUpdateRoomName" Content="Update Room Name" Style="{StaticResource ModernButton}" Margin="0,0,0,16" Click="BtnUpdateRoomName_Click"/>

                                <!-- Welcome Greeting Field -->
                                <TextBlock Text="WELCOME GREETING" FontSize="11" Foreground="#4F5660" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtGreeting" Text="Welcome to the server!" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                                <Button x:Name="btnUpdateGreeting" Content="Update Greeting" Style="{StaticResource ModernButton}" Margin="0,0,0,16" Click="BtnUpdateGreeting_Click"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Bottom Dir & Danger Zone -->
                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <Border Background="#F9F9F9" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Storage Directory" FontSize="10" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="lblStorage" Text="C:\..." FontSize="10" Foreground="#475569" TextWrapping="Wrap" FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="btnClearChat" Content="Clear Chat History" Style="{StaticResource DangerButton}" Margin="0,0,0,0" Click="BtnClearChat_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right Main Console Panel -->
                <Border Grid.Column="1" Background="#FFFFFF" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    <!-- Console Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="SERVER LIVE CONSOLE LOGS" Foreground="#313338" FontSize="15" FontFamily="Segoe UI" FontWeight="Bold"/>
                        <Border Height="1" Background="#E3E5E8" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Console Logs ListBox -->
                    <ListBox x:Name="lstLogs" Grid.Row="1" BorderThickness="0" Background="#F2F3F5" Padding="12" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Green bullet indicator -->
                                    <Border Grid.Column="0" Width="5" Height="5" CornerRadius="2.5" Background="#23A55A" Margin="4,7,10,0" VerticalAlignment="Top"/>
                                    <!-- Beautiful log entry -->
                                    <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#313338" FontSize="12.5" FontFamily="Consolas" TextWrapping="Wrap" LineHeight="18"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Border>
</Window>
